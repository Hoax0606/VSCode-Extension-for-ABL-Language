{
  "name": "ABL Dark",
  "type": "dark",
  "semanticHighlighting": true,

  "colors": {
    "editor.background": "#282A36",
    "editor.foreground": "#F8F8F2",
    "editorLineNumber.foreground": "#6272A4",
    "editorLineNumber.activeForeground": "#F8F8F2",

    "editorCursor.foreground": "#FF79C6",

    "editor.selectionBackground": "#44475A",
    "editor.inactiveSelectionBackground": "#3B3E52",
    "editor.selectionHighlightBackground": "#44475A",

    "editor.lineHighlightBackground": "#44475A",
    "editor.findMatchBackground": "#FFB86C66",
    "editor.findMatchHighlightBackground": "#FFB86C33",

    "editor.wordHighlightBackground": "#8BE9FD33",
    "editor.wordHighlightStrongBackground": "#8BE9FD55",

    "editorBracketMatch.background": "#BD93F933",
    "editorBracketMatch.border": "#BD93F9",

    "editorWhitespace.foreground": "#6272A466",
    "editorIndentGuide.background": "#6272A433",
    "editorIndentGuide.activeBackground": "#6272A466",

    "editorGutter.background": "#282A36",
    "editorGutter.modifiedBackground": "#FFB86C",
    "editorGutter.addedBackground": "#50FA7B",
    "editorGutter.deletedBackground": "#FF5555",

    "scrollbarSlider.background": "#6272A433",
    "scrollbarSlider.hoverBackground": "#6272A466",
    "scrollbarSlider.activeBackground": "#6272A499"
  },

  "semanticTokenColors": {
    "ablMap": "#FFB347",
    "ablFunc": "#f1fa8c",
    "ablLogic": "#f8c57c",
    "ablOperator": "#FFFFFF",
    "ablFunctionDecl": "#957DAD",
    "ablFunctionEnd": "#957DAD",
    "ablFunctionCall": "#61AFEF",
    "ablReturn": "#61AFEF"
  },
  "tokenColors": [
    {
      "name": "ABL Rule Name",
      "scope": ["entity.name.rule.abl", "string.description.rule.abl", "entity.name.type.system.abl"],
      "settings": { 
        "foreground": "#b5c2ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "ABL Separators and Markers",
      "scope": [
        "comment.block.marker.abl",
        "comment.punctuation.separator.abl",
        "comment.metadata.abl"
      ],
      "settings": { 
        "foreground": "#6272A4"
      }
    },
    {
      "name": "ABL Separator Line Numbers",
      "scope": ["comment.line.number.abl"],
      "settings": { "foreground": "#6272A4", "fontStyle": "italic" }
    },
    {
      "name": "ABL Comment",
      "scope": ["comment", "comment.line", "comment.line.number-sign"],
      "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
    },
    {
      "name": "ABL Boolean and Nullish",
      "scope": ["constant.language.boolean.abl", "constant.language.nullish.abl"],
      "settings": { "foreground": "#50fa7b" }
    },
    {
      "name": "ABL Numeric",
      "scope": ["constant.numeric.abl"],
      "settings": { "foreground": "#B5CEA8" }
    },
    {
      "name": "ABL Index",
      "scope": ["variable.other.index.abl"],
      "settings": { "foreground": "#bd93f9" }
    },
    {
      "name": "ABL Control Keywords",
      "scope": ["keyword.control"],
      "settings": { "foreground": "#ff79c6" }
    },
    {
      "name": "ABL Get Set",
      "scope": ["keyword.other.assignment", "support.class.map"],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "ABL Types",
      "scope": ["storage.type.abl"],
      "settings": { "foreground": "#8BE9FD" }
    },
    {
      "name": "ABL Writer",
      "scope": ["support.function.writer"],
      "settings": { "foreground":  "#FF8B94" }
    },
    {
      "name": "ABL Token and Meta Properties",
      "scope": [
        "support.class.token", 
        "support.class.meta",
        "variable.other.property.token", 
        "variable.other.property.meta", 
        "keyword.operator.reference"
      ],
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "name": "ABL General Functions",
      "scope": ["support.function"],
      "settings": { "foreground": "#f1fa8c" }
    }
  ]
}