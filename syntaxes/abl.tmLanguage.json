{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ABL",
  "scopeName": "source.abl",
  "patterns": [
    { "include": "#comments" },
    {
      "name": "comment.block.marker.abl",
      "match": "MMC1 End (Rule|Site) Data MMC1"
    },
    {
      "name": "comment.punctuation.separator.abl",
      "match": ">\\+\\|\\+<"
    },
    {
      "name": "comment.line.number.abl",
      "match": "(?<=>\\+\\|\\+<)\\s*\\d+\\s*(?=>\\+\\|\\+<|\\r?\\n|$)|<\\d+(?=>|$)"
    },
    {
      "name": "entity.name.rule.abl",
      "match": "(?<=AnyFile>\\+\\|\\+<)(.*?)(?=>\\+\\|\\+<)"
    },
    {
      "name": "entity.name.type.system.abl",
      "match": "(?<=<)(Pre|Post|Stored)(?=>)"
    },
    {
      "name": "string.description.rule.abl",
      "match": "(?<=Partial Support>\\+\\|\\+<Partial Support>\\+\\|\\+<)(.*?)(?=>\\+\\|\\+<)"
    },
    {
      "name": "comment.metadata.abl",
      "match": "^(?!\\s*[@#]|MMC1\\b).+?(?=>\\+\\|\\+<)"
    },
    {
      "name": "comment.metadata.abl",
      "match": "(?<=>\\+\\|\\+<)(?!\\s*[@#]).+?(?=>\\+\\|\\+<)"
    },
    { "include": "#numbers" },
    { "include": "#index" },
    { "include": "#control" },
    { "include": "#assignment" },
    { "include": "#types" },
    { "include": "#ablConstants" },
    { "include": "#mapCall" },
    { "include": "#map" },
    { "include": "#writer" },
    { "include": "#class" },
    { "include": "#data" },
    { "include": "#getCall" },
    { "include": "#functionCall" },
    { "include": "#functions" }
  ],
  "repository": {
    "ablConstants": {
      "patterns": [
        {
          "name": "constant.language.boolean.abl",
          "match": "(?<![A-Za-z0-9_])'?(?:True|False)'?@?(?![A-Za-z0-9_])"
        },
        {
          "name": "constant.language.nullish.abl",
          "match": "(?<![A-Za-z0-9_])'?\\[(?:NULL|_S_)\\]'?@?(?![A-Za-z0-9_])"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.abl",
          "match": "^[ \\t]*#.*$"
        },
        {
          "name": "comment.line.number-sign.abl",
          "match": "(?<=>\\+\\|\\+<)#.*$"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.abl", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "index": {
      "patterns": [
        {
          "name": "variable.other.index.abl",
          "match": "%[A-Za-z][A-Za-z0-9]*(?=[^A-Za-z0-9]|$)"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "(?<![A-Za-z0-9_])@End\\s+(For|If)(?![A-Za-z0-9_])"
        },
        {
          "name": "keyword.control",
          "match": "(?<![A-Za-z0-9_])@Else\\s+If(?![A-Za-z0-9_])"
        },
        {
          "name": "keyword.control",
          "match": "(?<![A-Za-z0-9_])@(If|Then|Else|For|End|Break|Continue|Return)(?![A-Za-z0-9_])"
        }
      ]
    },
    "assignment": {
      "patterns": [
        {
          "name": "keyword.other.assignment",
          "match": "(?<![A-Za-z0-9_])@(Get|Set)(?![A-Za-z0-9_])"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.abl",
          "match": "(?<![A-Za-z0-9_])@(String|Int)(?![A-Za-z0-9_])"
        }
      ]
    },
    "getCall": {
      "patterns": [
        {
          "match": "(?<![A-Za-z0-9_])(@Get\\()([A-Za-z_][A-Za-z0-9_]*)(\\))",
          "captures": {
            "1": { "name": "keyword.other.assignment" },
            "3": { "name": "keyword.other.assignment" }
          }
        }
      ]
    },
    "mapCall": {
      "patterns": [
        {
          "name": "meta.function-call.map.abl",
          "begin": "(?<![A-Za-z0-9_])@Map\\.(Get|Set)@?\\s*@?\\(",
          "beginCaptures": {
            "0": { "name": "support.class.map" }
          },
          "end": "@?\\)|(?=$)",
          "applyEndPatternLast": 1,
          "endCaptures": {
            "0": { "name": "support.class.map" }
          },
          "patterns": [
            { "include": "#getCall" },
            { "include": "#functionCall" },
            {
              "name": "support.class.map",
              "match": "(?<=[A-Za-z0-9_])@(?!Get\\b)(?!Set\\b)"
            },
            {
              "name": "support.class.map",
              "match": "@(?!Get\\b)(?!Set\\b)(?=\\s*[(),\\]\\|'\"])"
            },
            {
              "name": "support.class.map",
              "match": "(?<=[),\\]\\|'\"!])@(?!Get\\b)(?!Set\\b)"
            },
            {
              "name": "support.class.map",
              "match": "(?<=!)@(?!Get\\b)(?!Set\\b)"
            },
            { "include": "#class" },
            { "include": "#data" },
            { "include": "#index" },
            { "include": "#numbers" },
            { "include": "#ablConstants" },
            { "include": "#map" },
            { "include": "#writer" },
            { "include": "#functions" }
          ]
        }
      ]
    },
    "map": {
      "patterns": [
        {
          "name": "support.class.map",
          "match": "(?<![A-Za-z0-9_])@Map\\.(Get|Set|Clear)@?(?=@|\\(|\\s)"
        }
      ]
    },
    "writer": {
      "patterns": [
        {
          "name": "support.function.writer",
          "match": "(?<![A-Za-z0-9_])@(Data|Base|AddLine|AddLinePrespace|InsertLine|InsertLinePrespace)@?(?![A-Za-z0-9_])"
        }
      ]
    },
    "class": {
      "patterns": [
        {
          "name": "support.class.meta",
          "match": "\\^Class(?=\\.)"
        },
        {
          "name": "variable.other.property.meta",
          "match": "\\.(Name|Tobe|Extends|Package)(?=!)"
        },
        {
          "name": "keyword.operator.reference",
          "match": "!"
        }
      ]
    },
    "data": {
      "patterns": [
        {
          "name": "support.class.token",
          "match": "\\^Data\\.(?:Count|Item)(?=\\[|!)"
        },
        {
          "name": "support.class.token",
          "match": "\\.StringTokenInfo(?=\\[)"
        },
        {
          "name": "variable.other.property.token",
          "match": "\\.(Name|Tobe|Type|TobeType|Length|NewLine|Line|Block_Level|Level|Format|Prespace|Pretab|Column)(?=!)"
        },
        {
          "name": "keyword.operator.reference",
          "match": "!"
        }
      ]
    },
    "functionCall": {
      "patterns": [
        {
          "name": "meta.function-call.abl",
          "begin": "(?<![A-Za-z0-9_])@(?!Map\\.)(?!Get\\b)(?!Set\\b)(?!Data\\b)(?!Base\\b)(?!AddLine\\b)(?!AddLinePrespace\\b)(?!InsertLine\\b)(?!InsertLinePrespace\\b)([A-Za-z_][A-Za-z0-9_]*)@?\\s*@?\\(",
          "beginCaptures": {
            "0": { "name": "support.function" }
          },
          "end": "@?\\)|(?=$)",
          "applyEndPatternLast": 1,
          "endCaptures": {
            "0": { "name": "support.function" }
          },
          "patterns": [
            { "include": "#getCall" },
            { "include": "#mapCall" },
            { "include": "#functionCall" },
            {
              "name": "support.function",
              "match": "(?<=[A-Za-z0-9_])@(?!Get\\b)(?!Set\\b)"
            },
            {
              "name": "support.function",
              "match": "@(?!Get\\b)(?!Set\\b)(?=\\s*[(),\\]\\|'\"])"
            },
            {
              "name": "support.function",
              "match": "(?<=[),\\]\\|'\"!])@(?!Get\\b)(?!Set\\b)"
            },
            {
              "name": "support.function",
              "match": "(?<=!)@(?!Get\\b)(?!Set\\b)"
            },
            { "include": "#numbers" },
            { "include": "#index" },
            { "include": "#class" },
            { "include": "#data" },
            { "include": "#ablConstants" },
            { "include": "#map" },
            { "include": "#writer" },
            { "include": "#functions" }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function",
          "match": "(?<![A-Za-z0-9_])@[A-Za-z_][A-Za-z0-9_]*@?(?![A-Za-z0-9_])"
        }
      ]
    }
  }
}