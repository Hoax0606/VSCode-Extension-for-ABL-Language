{
  "name": "abl-language",
  "displayName": "abl-language",
  "description": "ABL language support for VS Code",
  "version": "1.0.2",
  "publisher": "hoax0606",
  "icon": "images/VSCode_ABL_Extension_Icon_rounded_square.png",
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hoax0606/VSCode-Extension-for-ABL-Language.git"
  },
  "bugs": {
    "url": "https://github.com/Hoax0606/VSCode-Extension-for-ABL-Language/issues"
  },
  "homepage": "https://github.com/Hoax0606/VSCode-Extension-for-ABL-Language#readme",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:abl"
  ],
  "main": "./out/extension.js",
  "contributes": {
  "configuration": {
        "title": "ABL SmartBridge",
        "properties": {
          "abl.smartBridge.enableRunOnSave": {
            "type": "boolean",
            "default": true,
            "description": "Enable or disable automatic execution of the SmartBridge DB integration script on save."
          },
          "abl.smartBridge.scriptPath": {
            "type": "string",
            "default": "C:\\VAF\\SmartBridge_JPN\\Connect.ps1",
            "description": "Path of Connect.ps1."
          },
          "abl.smartBridge.deleteScriptPath": {
            "type": "string",
            "default": "C:\\VAF\\SmartBridge_JPN\\Delete_Rule.ps1",
            "description": "Path of Delete_Rule.ps1."
          }
        }
      },
    "commands": [
      { "command": "abl.deleteRule", "title": "Delete Rule from DB" },
      { "command": "abl.addRuleGeneral", "title": "ABL: Add New Rule" },
      { "command": "abl.addRulePre", "title": "ABL: Add Preprocessing" },
      { "command": "abl.addRulePost", "title": "ABL: Add Postprocessing" },
      { "command": "abl.addRuleStored", "title": "ABL: Add User Function" }
    ],
    "languages": [
      {
        "id": "abl",
        "aliases": ["ABL", "abl"],
        "extensions": [".abl", ".rule"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "abl",
        "scopeName": "source.abl",
        "path": "./syntaxes/abl.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "ablMap": "#FFB347",
          "ablFunc": "#f1fa8c",
          "ablLogic": "#f8c57c",
          "ablData": "#9CDCFE",
          "ablOperator": "#FFFFFF",
          "ablFunctionDecl": "#957DAD",
          "ablFunctionEnd": "#957DAD",
          "ablFunctionCall": "#61AFEF",
          "ablReturn": "#61AFEF"
        }
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": ["entity.name.rule.abl", "string.description.rule.abl", "entity.name.type.system.abl"],
            "settings": { "foreground": "#b5c2ff", "fontStyle": "bold" }
          },
          {
            "scope": ["comment.block.marker.abl", "comment.punctuation.separator.abl", "comment.metadata.abl"],
            "settings": { "foreground": "#6272A4" }
          },
          {
            "scope": "comment.line.number.abl",
            "settings": { "foreground": "#6272A4", "fontStyle": "italic" }
          },
          {
            "scope": ["comment", "comment.line", "comment.line.number-sign"],
            "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
          },
          {
            "scope": ["constant.language.boolean.abl", "constant.language.nullish.abl"],
            "settings": { "foreground": "#50fa7b" }
          },
          {
            "scope": "constant.numeric.abl",
            "settings": { "foreground": "#B5CEA8" }
          },
          {
            "scope": "variable.other.index.abl",
            "settings": { "foreground": "#bd93f9" }
          },
          {
            "scope": "keyword.control",
            "settings": { "foreground": "#ff79c6" }
          },
          {
            "scope": ["keyword.other.assignment", "support.class.map"],
            "settings": { "foreground": "#FFB347" }
          },
          {
            "scope": "storage.type.abl",
            "settings": { "foreground": "#8Be9fd" }
          },
          {
            "scope": "support.function.writer",
            "settings": { "foreground": "#FF8B94" }
          },
          {
            "scope": ["support.class.token", "support.class.meta", "variable.other.property.token", "variable.other.property.meta", "keyword.operator.reference"],
            "settings": { "foreground": "#9CDCFE" }
          },
          {
            "scope": "support.function",
            "settings": { "foreground": "#f1fa8c" }
          }
        ]
      }
    },
    "semanticTokenTypes": [
      {
        "id": "ablMap",
        "description": "ABL Map context token",
        "superType": "function"
      },
      {
        "id": "ablFunc",
        "description": "ABL Function context token",
        "superType": "function"
      },
      {
        "id": "ablLogic",
        "description": "ABL logic operator token (And/Or)",
        "superType": "operator"
      },
      {
        "id": "ablData",
        "description": "ABL meta data token (^Data/^Class)",
        "superType": "variable"
      },
      {
        "id": "ablFunctionDecl",
        "description": "ABL user function declaration",
        "superType": "function"
      },
      {
        "id": "ablFunctionEnd",
        "description": "ABL user function end statement",
        "superType": "keyword"
      },
      {
        "id": "ablFunctionCall",
        "description": "ABL user function call",
        "superType": "function"
      },
      {
        "id": "ablReturn",
        "description": "ABL return variable token",
        "superType": "variable"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "abl",
        "scopes": {
          "ablMap": ["entity.name.function"],
          "ablFunc": ["entity.name.function"],
          "ablLogic": ["keyword.operator"],
          "ablData": ["variable.other"],
          "ablFunctionDecl": ["entity.name.function"],
          "ablFunctionEnd": ["keyword.control"],
          "ablFunctionCall": ["entity.name.function.call"],
          "ablReturn": ["variable.other.readwrite"]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}